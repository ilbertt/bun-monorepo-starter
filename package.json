{
  "name": "bun-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^6.0.3"
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun run --bun turbo build",
    "check:types": "bun run --bun turbo check:types",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check:codestyle": "bun lint && bun format:check",
    "check:all": "bun check:types && bun check:codestyle",
    "check:commit-message": "bun run --bun commitlint",
    "fix:codestyle": "bun lint:fix && bun format"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/format": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.10.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
